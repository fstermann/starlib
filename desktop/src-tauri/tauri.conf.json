{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Starlib",
    "identifier": "com.starlib.Starlib",
    "version": "0.6.0",
    "build": {
        "frontendDist": "../../frontend/out",
        "devUrl": "http://localhost:3000",
        "beforeDevCommand": "cd ../frontend && npm run dev",
        "beforeBuildCommand": "cd ../frontend && NEXT_PUBLIC_API_URL=http://127.0.0.1:8000 npm run build"
    },
    "app": {
        "windows": [
            {
                "title": "Starlib",
                "width": 1280,
                "height": 820,
                "minWidth": 900,
                "minHeight": 600,
                "resizable": true,
                "fullscreen": false,
                "decorations": true,
                "transparent": false,
                "center": true,
                "visible": true,
                "titleBarStyle": "Overlay",
                "hiddenTitle": true
            }
        ],
        "security": {
            "csp": "default-src 'self' tauri: asset: http://127.0.0.1:8000; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: http://127.0.0.1:8000 https://i1.sndcdn.com https://a1.sndcdn.com; media-src 'self' blob: http://127.0.0.1:8000 https://*.sndcdn.com https://*.soundcloud.cloud; connect-src 'self' http://127.0.0.1:8000 https://secure.soundcloud.com https://api.soundcloud.com https://api-v2.soundcloud.com https://*.sndcdn.com https://*.soundcloud.cloud https://github.com https://objects.githubusercontent.com; frame-src https://w.soundcloud.com",
            "dangerousDisableAssetCspModification": true
        }
    },
    "bundle": {
        "active": true,
        "createUpdaterArtifacts": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "macOS": {
            "entitlements": "Entitlements.plist",
            "exceptionDomain": "",
            "frameworks": [],
            "providerShortName": null,
            "signingIdentity": "-"
        },
        "externalBin": [
            "binaries/starlib-backend"
        ]
    },
    "plugins": {
        "updater": {
            "active": true,
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg0NjM2ODBBNDU1MzdEREEKUldUYWZWTkZDbWhqaEd6U0JFRHJuZ0Uvd0FSN2dLci9ya09wN2QweWxBV1JGbkRscnVTUW9ZOTQK",
            "endpoints": [
                "https://github.com/fstermann/starlib/releases/latest/download/latest.json"
            ]
        },
        "shell": {
            "open": true
        },
        "deep-link": {
            "mobile": [],
            "desktop": {
                "schemes": [
                    "starlib"
                ]
            }
        }
    }
}
