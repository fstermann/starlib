# SoundCloud API Credentials
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here
USER_ID=your_user_id_here

# Authentication Method 1: Client Credentials (read-only, for browsing/searching)
# Leave blank to auto-authenticate with CLIENT_ID and CLIENT_SECRET
OAUTH_TOKEN=

# Authentication Method 2: User OAuth (read/write, for creating playlists)
# Run: poetry run python get_user_tokens.py
# Then paste the tokens here:
SOUNDCLOUD_OAUTH_TOKEN=
SOUNDCLOUD_REFRESH_TOKEN=

# Required for the weekly playlist generation (legacy)
DATADOME_CLIENTID=
SC_A_ID=

# Optional
PROXY=
ROOT_MUSIC_FOLDER=
